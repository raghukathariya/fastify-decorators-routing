{
  "name": "fastify-decorators-routing",
  "version": "1.0.0",
  "description": "A decorator-based routing framework for Fastify v5+, built for minimal overhead and maximum performance.",
  "keywords": [
    "fastify",
    "decorators",
    "routing",
    "controllers",
    "typescript",
    "dependency-injection",
    "rest",
    "api"
  ],
  "homepage": "https://github.com/raghukathariya/fastify-decorators-routing#readme",
  "bugs": {
    "url": "https://github.com/raghukathariya/fastify-decorators-routing/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/raghukathariya/fastify-decorators-routing.git"
  },
  "license": "MIT",
  "author": {
    "name": "Raghu Chaudhari",
    "email": "raghu.chaudhari@gmail.com"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@11.12.1",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage .tsbuildinfo",
    "benchmark": "npm run build && node benchmark/framework-overhead.mjs",
    "prepare": "husky",
    "prepublishOnly": "npm run ci && npm run build",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "npm run build && changeset publish",
    "ci": "npm run lint && npm run typecheck && npm run test:coverage"
  },
  "peerDependencies": {
    "fastify": ">=5.0.0",
    "reflect-metadata": ">=0.2.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.11",
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@eslint/js": "^9.18.0",
    "@fastify/multipart": "^10.1.0",
    "@fastify/swagger": "^9.8.1",
    "@swc/core": "^1.15.46",
    "@types/node": "^22.10.7",
    "@vitest/coverage-v8": "^3.0.4",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "fastify": "^5.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.1",
    "prettier": "^3.4.2",
    "reflect-metadata": "^0.2.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "unplugin-swc": "^1.5.9",
    "vitest": "^3.0.4"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,cjs,mjs,json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "fast-glob": "^3.3.3"
  }
}
